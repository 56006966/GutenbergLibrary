<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/libraryRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:id="@+id/libraryContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/libraryShelfTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/shelf_my_library"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/libraryThemeButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/toggle_theme"
                android:padding="8dp"
                android:src="@drawable/ic_theme_moon" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/librarySortButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:contentDescription="@string/library_sort_content_description"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/library_sort_title_asc"
                android:textAllCaps="false"
                app:backgroundTint="#E7C690"
                app:cornerRadius="0dp"
                app:icon="@android:drawable/arrow_down_float"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:strokeColor="#FFF0D1"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/libraryEmptyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/library_empty_state"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/libraryRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/shelf_row_background"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:paddingStart="6dp"
            android:paddingTop="10dp"
            android:paddingEnd="6dp"
            android:paddingBottom="18dp"
            android:scrollbars="horizontal" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/newestShelfTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/shelf_newest_releases"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/newestSortButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:contentDescription="@string/library_sort_content_description"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/library_sort_recent_desc"
                android:textAllCaps="false"
                app:backgroundTint="#E7C690"
                app:cornerRadius="0dp"
                app:icon="@android:drawable/arrow_down_float"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:strokeColor="#FFF0D1"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/newestLoadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/remote_shelf_loading" />

        <TextView
            android:id="@+id/newestEmptyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/remote_shelf_empty"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/newestRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/shelf_row_background"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:paddingStart="6dp"
            android:paddingTop="10dp"
            android:paddingEnd="6dp"
            android:paddingBottom="18dp"
            android:scrollbars="horizontal" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/popularShelfTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/shelf_most_popular"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/popularSortButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:contentDescription="@string/library_sort_content_description"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/library_sort_popular_desc"
                android:textAllCaps="false"
                app:backgroundTint="#E7C690"
                app:cornerRadius="0dp"
                app:icon="@android:drawable/arrow_down_float"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:strokeColor="#FFF0D1"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/popularLoadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/remote_shelf_loading" />

        <TextView
            android:id="@+id/popularEmptyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/remote_shelf_empty"
            android:visibility="gone" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/popularRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/shelf_row_background"
            android:clipToPadding="false"
            android:nestedScrollingEnabled="false"
            android:paddingStart="6dp"
            android:paddingTop="10dp"
            android:paddingEnd="6dp"
            android:paddingBottom="18dp"
            android:scrollbars="horizontal" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
