<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bookCard"
    android:layout_width="132dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="0dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="0dp">

        <FrameLayout
            android:id="@+id/bookCoverContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false">

            <View
                android:id="@+id/bookBackCover"
                android:layout_width="120dp"
                android:layout_height="180dp"
                android:layout_gravity="end"
                android:alpha="1"
                android:background="#453225" />

            <View
                android:id="@+id/bookPage6"
                android:layout_width="120dp"
                android:layout_height="180dp"
                android:alpha="0"
                android:background="#FDFBF7" />

            <View
                android:id="@+id/bookPage5"
                android:layout_width="120dp"
                android:layout_height="180dp"
                android:alpha="0"
                android:background="#FAF7F1" />

            <View
                android:id="@+id/bookPage4"
                android:layout_width="120dp"
                android:layout_height="180dp"
                android:alpha="0"
                android:background="#F7F3ED" />

            <View
                android:id="@+id/bookPage3"
                android:layout_width="120dp"
                android:layout_height="180dp"
                android:alpha="0"
                android:background="#F5F1EA" />

            <View
                android:id="@+id/bookPage2"
                android:layout_width="120dp"
                android:layout_height="180dp"
                android:alpha="0"
                android:background="#F1ECE4" />

            <View
                android:id="@+id/bookPage1"
                android:layout_width="120dp"
                android:layout_height="180dp"
                android:alpha="0"
                android:background="#ECE6DD" />

            <View
                android:id="@+id/bookPageEdge"
                android:layout_width="6dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:alpha="1"
                android:background="@drawable/book_page_edge_background" />

            <ImageView
                android:id="@+id/bookCover"
                android:layout_width="120dp"
                android:layout_height="180dp"
                android:layout_gravity="end"
                android:background="@drawable/book_placeholder"
                android:contentDescription="@string/book_cover"
                android:scaleType="centerCrop" />

            <LinearLayout
                android:id="@+id/bookSpine"
                android:layout_width="44dp"
                android:layout_height="180dp"
                android:layout_gravity="start"
                android:background="@drawable/book_spine_background"
                android:elevation="2dp"
                android:gravity="center"
                android:orientation="vertical"
                android:alpha="1"
                android:paddingStart="0dp"
                android:paddingTop="0dp"
                android:paddingEnd="0dp"
                android:paddingBottom="0dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:background="#26FFFFFF" />

                <TextView
                    android:id="@+id/bookSpineTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="18dp"
                    android:layout_marginEnd="4dp"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="3"
                    android:text="Book Title"
                    android:textColor="#F7F1E7"
                    android:textSize="8sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginEnd="6dp"
                    android:background="#66E8D4AE" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="10dp"
                    android:background="#19000000" />
            </LinearLayout>

            <View
                android:id="@+id/bookCoverOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0"
                android:background="#C9000000" />

            <LinearLayout
                android:id="@+id/bookHoverInfo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/bookOverlayTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="3"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/bookActionsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:padding="8dp"
                android:visibility="gone">

                <ImageButton
                    android:id="@+id/favoriteButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="start|top"
                    android:background="#70000000"
                    android:contentDescription="@string/favorite_book"
                    android:padding="4dp"
                    android:src="@android:drawable/btn_star_big_off" />

                <ImageButton
                    android:id="@+id/removeButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="end|top"
                    android:background="#70000000"
                    android:contentDescription="@string/remove_book"
                    android:padding="4dp"
                    android:src="@android:drawable/ic_menu_delete" />
            </FrameLayout>

            <ImageView
                android:id="@+id/favoriteBadge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="top|start"
                android:layout_margin="6dp"
                android:contentDescription="@string/favorite_book"
                android:src="@android:drawable/btn_star_big_on"
                android:tint="#E3B341"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/bookTitle"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="0dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Book Title"
            android:textColor="@android:color/black"
            android:textSize="12sp" />
    </FrameLayout>
</com.google.android.material.card.MaterialCardView>
