<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="132dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="6dp">

        <FrameLayout
            android:id="@+id/bookCoverContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/bookCover"
                android:layout_width="120dp"
                android:layout_height="180dp"
                android:background="@drawable/book_placeholder"
                android:contentDescription="@string/book_cover"
                android:scaleType="centerCrop" />

            <View
                android:id="@+id/bookCoverOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0"
                android:background="#C9000000" />

            <LinearLayout
                android:id="@+id/bookHoverInfo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/bookOverlayTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:maxLines="3"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/bookActionsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:padding="8dp"
                android:visibility="gone">

                <ImageButton
                    android:id="@+id/favoriteButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="start|top"
                    android:background="#70000000"
                    android:contentDescription="@string/favorite_book"
                    android:padding="4dp"
                    android:src="@android:drawable/btn_star_big_off" />

                <ImageButton
                    android:id="@+id/removeButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="end|top"
                    android:background="#70000000"
                    android:contentDescription="@string/remove_book"
                    android:padding="4dp"
                    android:src="@android:drawable/ic_menu_delete" />
            </FrameLayout>

            <ImageView
                android:id="@+id/favoriteBadge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="top|start"
                android:layout_margin="6dp"
                android:contentDescription="@string/favorite_book"
                android:src="@android:drawable/btn_star_big_on"
                android:tint="#E3B341"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/bookTitle"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="2dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="Book Title"
            android:textColor="@android:color/black"
            android:textSize="12sp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
