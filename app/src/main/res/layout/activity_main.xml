<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/nav_host_fragment_content_main"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:defaultNavHost="true"
            app:navGraph="@navigation/nav_graph"
            tools:layout="@layout/fragment_library" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/openDrawerButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="24dp"
            android:contentDescription="@string/open_navigation"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:backgroundTint="@android:color/black"
            app:tint="@android:color/white" />

        <FrameLayout
            android:id="@+id/launchLoadingOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0"
            android:background="#F3E7D2"
            android:clickable="false"
            android:focusable="false"
            android:visibility="gone">

            <com.kdhuf.projectgutenberglibrary.ui.LaunchTileWallView
                android:id="@+id/launchTileWall"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#E6000000"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingStart="28dp"
                    android:paddingTop="24dp"
                    android:paddingEnd="28dp"
                    android:paddingBottom="24dp">

                    <TextView
                        android:id="@+id/launchLoadingTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/launch_loading_title"
                        android:textColor="#F5F1E8"
                        android:textSize="34sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/launchLoadingSubtitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:text="@string/launch_loading_subtitle"
                        android:textColor="#E0D5C5"
                        android:textSize="16sp" />

                    <ProgressBar
                        android:id="@+id/launchLoadingProgress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="220dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:indeterminate="true"
                        android:indeterminateTint="#F5F1E8" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header_search"
        app:menu="@menu/activity_main_drawer" />
</androidx.drawerlayout.widget.DrawerLayout>
